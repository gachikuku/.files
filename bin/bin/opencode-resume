#!/bin/sh
# opencode-resume — fuzzy-pick ANY past opencode session from anywhere and
# resume it in its ORIGINAL directory.
#
# opencode scopes the TUI session switcher to the current project, so sessions
# from other directories are invisible. This queries all stored sessions and
# resumes the selected one from its recorded directory.
#
# Deps: jq, fzf, opencode. Bind to a key or alias `ocr=opencode-resume`.

# Hidden mode: render session metadata and recent messages for the preview.
if [ "$1" = "--preview" ]; then
    opencode export "$2" 2>/dev/null | jq -r '
        .info as $info |
        "title:     \($info.title // "-")",
        "directory: \($info.directory // "-")",
        "updated:   \(($info.time.updated // 0)/1000|floor|localtime|strftime("%Y-%m-%d %H:%M"))",
        "---",
        ([.messages[]? | .info.role as $role | .parts[]?
          | select(.type == "text" and ((.text // "") | length > 0))
          | (if $role == "user" then ">> " else "   " end)
            + ((.text // "") | gsub("[\\t\\r\\n]+"; " ") | .[0:500])][-40:][])' 2>/dev/null
    exit 0
fi

rows=$(opencode db --format json '
    SELECT time_updated AS updated, id, directory, title
    FROM session
    ORDER BY time_updated DESC
' 2>/dev/null | jq -r '.[] |
    [(.updated // 0),
     ((.updated // 0)/1000|floor|localtime|strftime("%m-%d %H:%M")),
     .id,
     ((.directory // "-")|gsub("[\t\r\n]";" ")),
     ((.title // "")|gsub("[\t\r\n]";" ")|.[0:70])] | @tsv' 2>/dev/null)

[ -n "$rows" ] || { echo "no opencode sessions found" >&2; exit 1; }

pick=$(printf '%s\n' "$rows" | fzf \
    --delimiter='\t' --with-nth=2,4,5 \
    --no-hscroll --header='opencode-resume — any session, anywhere' \
    --preview="$0 --preview {3}" --preview-window=up,55%,wrap) || exit 0

sid=$(printf '%s' "$pick" | cut -f3)
dir=$(printf '%s' "$pick" | cut -f4)
[ -d "$dir" ] || { echo "dir gone: $dir — resuming in \$PWD" >&2; dir="$PWD"; }
cd "$dir" || exit 1
exec opencode --session "$sid"
