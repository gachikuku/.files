#!/usr/bin/env bash
# Check if URL argument is provided
if [ -z "$1" ]; then
    echo "Error: URL argument is missing"
    echo "Usage: $0 <YouTube URL>"
    exit 1
fi

URL="$1"

# Download English subtitles (manual first, then auto-generated fallback).
# "en.*" matches en, en-US, en-GB, en-orig, etc.
yt-dlp --skip-download \
       --write-subs \
       --write-auto-subs \
       --sub-lang "en.*" \
       --sub-format ttml \
       --convert-subs srt \
       --output "transcript.%(ext)s" \
       "$URL"

# Find whatever .srt file was produced (name includes the matched lang tag)
srt_file=$(ls transcript.*.srt 2>/dev/null | head -n1)

if [ -z "$srt_file" ]; then
    echo "Error: no English subtitle file was downloaded."
    exit 1
fi

echo "Using subtitle file: $srt_file"

# Strip timestamps, sequence numbers, and HTML-like tags (BSD sed)
sed -i '' \
  -e '/^[0-9]\{2\}:[0-9]\{2\}:[0-9]\{2\},[0-9]\{3\} --> [0-9]\{2\}:[0-9]\{2\}:[0-9]\{2\},[0-9]\{3\}$/d' \
  -e '/^[[:digit:]]\{1,3\}$/d' \
  -e 's/<[^>]*>//g' \
  "$srt_file"

# Remove blank lines and open in nvim
sed -e 's/<[^>]*>//g' -e '/^[[:space:]]*$/d' "$srt_file" | nvim -

# Clean up
rm "$srt_file"
